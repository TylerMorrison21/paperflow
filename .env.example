# OpenRouter (vision OCR — fallback when MARKER_URL is not set)
OPENROUTER_API_KEY=your_openrouter_api_key
# Optional: override the vision model (default: qwen/qwen3.5-plus-02-15)
# OPENROUTER_MODEL=qwen/qwen3.5-plus-02-15

# Claude Vision enhancement (optional, only needed if ai_enhance=True)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Datalab hosted Marker API — sign up at https://www.datalab.to
DATALAB_API_KEY=your_datalab_api_key

# Stripe payments
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
