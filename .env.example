# Datalab Marker API — sign up at https://www.datalab.to
DATALAB_API_KEY=your_datalab_api_key
MARKER_API_URL=https://www.datalab.to/api/v1/marker

# Resend Email API — sign up at https://resend.com
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=papers@paperflow.dev

# CORS origins (comma-separated or *)
CORS_ORIGINS=*

# Data directory for job storage
DATA_DIR=./data/jobs

# Trial / abuse limits
MAX_PAGES=15
PER_EMAIL_DAILY_LIMIT=3
PER_USER_TRIAL_PAGE_LIMIT=100

# Comma-separated allowlist for Pro users (skip free-trial gates)
PRO_EMAILS=
